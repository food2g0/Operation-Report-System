# REST API Configuration
# Copy this to .env and update values for your environment

# API Server Settings
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False
API_SECRET_KEY=your-super-secret-key-change-in-production

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# Database Configuration (inherited from config.py DB_CONFIG)
# Note: The API uses the same database connection as the main application

# Client API Settings (for PyQt5 clients)
# CLIENT_API_URL=http://localhost:5000
# CLIENT_API_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
