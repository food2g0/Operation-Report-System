.idea/
*.swp
*.swo
*~

# Logs
*.log
database.log
performance.log
db_deadlock_retries.log

# Environment
.env
.env.local

# Private / Secrets
# Keep templates tracked, ignore real local secret files.
!.env.example
.env.*
*.secret
*.secrets
secrets.*
private.*

# Keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
id_rsa
id_ed25519

# Encrypted config/data artifacts
*.enc

# Runtime/local state that may contain sensitive data
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
~$*
*.bak
*.swp

# Generated reports (optional - remove if you want to track them)
*.docx
*.xlsx
!template*.docx
!template*.xlsx

# Test/development files
test_*.py
check_*.py
inspect_*.py
*_example.py

# Database
*.sql.backup
*.db

# Build outputs
*.exe
*.msi
Output/
