2026-03-10 14:37:28,920 - ERROR - Query failed: (pymysql.err.OperationalError) (1267, "Illegal mix of collations (utf8mb4_general_ci,IMPLICIT) and (utf8mb4_0900_ai_ci,IMPLICIT) for operation '='")
[SQL: 
                    SELECT dr.branch,
                           COALESCE(b.area, 'UNASSIGNED') as area,
                           COALESCE(c.name, '') as corporation_name,
                           COALESCE(b.line_of_business, '') as line_of_business,
                           COALESCE(b.global_tag, '') as global_tag,
                           COALESCE(b.sunday, '') as sunday,
                           COALESCE(dr.cash_count, 0) as cash_count,
                           COALESCE(cf.cash_float, 0) as cash_float
                    FROM daily_reports_brand_a dr
                    INNER JOIN branches b ON dr.branch = b.name
                    LEFT JOIN corporations c ON b.corporation_id = c.id
                    LEFT JOIN cash_float_tbl cf ON dr.branch = cf.branch
